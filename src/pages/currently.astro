---
import { getEntry } from 'astro:content';
import SpecialPageLayout from '../layouts/SpecialPageLayout.astro';

const entry = await getEntry('currently', 'index');
const { Content } = await entry.render();
const { title, subtitle, updatedDate } = entry.data;
---

<SpecialPageLayout
  {title}
  {subtitle}
  sectionLabel="The Current State"
  {updatedDate}
  activeNav="Currently"
>
  <div class="currently-grid">
    <Content />
  </div>
</SpecialPageLayout>

<style>
  .currently-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .currently-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
