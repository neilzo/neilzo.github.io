---
import SpecialPageLayout from '../layouts/SpecialPageLayout.astro';
import FavoritesSection from '../components/favorites/FavoritesSection.astro';
import FavoritesEntry from '../components/favorites/FavoritesEntry.astro';
---

<SpecialPageLayout
  title="Favorites"
  subtitle="A curated record of things that have stayed with me."
  sectionLabel="The Curated Record"
  activeNav="Favorites"
>
  <FavoritesSection index="01" title="Cinema" subtitle="Films & TV">
    <FavoritesEntry
      year="1985"
      title="Come and See"
      creator="Klimov"
      description="The most visceral anti-war film ever made. The final scene dismantles everything. I've never recovered."
    />
    <FavoritesEntry
      year="2001"
      title="Mulholland Drive"
      creator="Lynch"
      description="A film about the gap between what we imagine our lives to be and what they are."
    />
    <FavoritesEntry
      year="2018"
      title="Shoplifters"
      creator="Kore-eda"
      description="The gentlest demolition of the idea of family I've ever seen."
    />
    <FavoritesEntry
      year="1963"
      title="The Great Escape"
      creator="Sturges"
      description="Peak ensemble filmmaking. Still holds up completely."
    />
  </FavoritesSection>

  <FavoritesSection index="02" title="Games" subtitle="Video & Tabletop">
    <FavoritesEntry
      year="2015"
      title="Bloodborne"
      creator="FromSoftware"
      description="The atmosphere is unmatched. Everything about it — the music, the lore, the creature design — coheres into something genuinely disquieting."
    />
    <FavoritesEntry
      year="2022"
      title="Elden Ring"
      creator="FromSoftware"
      description="The open world finally clicked for me on the second playthrough. The best map design in any game."
    />
    <FavoritesEntry
      year="1998"
      title="Metal Gear Solid"
      creator="Kojima"
      description="Formative. I think about the Codec conversations more than most conversations I've had in real life."
    />
  </FavoritesSection>

  <FavoritesSection index="03" title="Books" subtitle="Fiction & Non-fiction">
    <FavoritesEntry
      year="1974"
      title="Zen and the Art of Motorcycle Maintenance"
      creator="Pirsig"
      description="The argument about Quality is more interesting than the motorcycle journey, but you need the motorcycle journey."
    />
    <FavoritesEntry
      year="1997"
      title="Underworld"
      creator="DeLillo"
      description="The most ambitious American novel of the last fifty years. The prologue alone."
    />
    <FavoritesEntry
      year="2005"
      title="The Road"
      creator="McCarthy"
      description="Formally perfect. The prose is doing everything the story needs and nothing it doesn't."
    />
  </FavoritesSection>

  <FavoritesSection index="04" title="Music">
    <FavoritesEntry
      year="1971"
      title="What's Going On"
      creator="Marvin Gaye"
      description="The album I've returned to more times than any other. Completely whole."
    />
    <FavoritesEntry
      year="1987"
      title="Sign 'O' the Times"
      creator="Prince"
      description="The breadth of it is staggering. Two records, no filler, complete command of every genre he touches."
    />
    <FavoritesEntry
      year="2001"
      title="Is This It"
      creator="The Strokes"
      description="I know it's a cliché but I was fifteen and it changed my understanding of what rock music could sound like."
    />
  </FavoritesSection>
</SpecialPageLayout>
