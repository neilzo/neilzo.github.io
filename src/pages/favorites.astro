---
import { getEntry } from 'astro:content';
import SpecialPageLayout from '../layouts/SpecialPageLayout.astro';

const entry = await getEntry('favorites', 'index');
const { Content } = await entry.render();
const { title, subtitle, updatedDate } = entry.data;
---

<SpecialPageLayout
  {title}
  {subtitle}
  sectionLabel="The Curated Record"
  {updatedDate}
  activeNav="Favorites"
>
  <Content />
</SpecialPageLayout>
