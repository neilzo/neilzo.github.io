---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PostCard from '../../components/posts/PostCard.astro';
import PostCardPhoto from '../../components/posts/PostCardPhoto.astro';
import Pagination from '../../components/ui/Pagination.astro';
import { getAllPosts } from '../../utils/getAllPosts';

export async function getStaticPaths() {
  const PAGE_SIZE = 8;
  const allPosts = await getAllPosts();
  const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

  return Array.from({ length: totalPages }, (_, i) => {
    const page = i + 1;
    const start = i * PAGE_SIZE;
    const pagePosts = allPosts.slice(start, start + PAGE_SIZE);
    return {
      params: { page: String(page) },
      props: {
        pagePosts,
        currentPage: page,
        lastPage: totalPages,
        totalPosts: allPosts.length,
      },
    };
  });
}

const { pagePosts, currentPage, lastPage, totalPosts } = Astro.props;
---

<SiteLayout title={`Page ${currentPage} — The Ordered Archive`} activeNav="Home">
  <div class="feed-header">
    <div class="feed-header__eyebrow">
      <span class="feed-issue">The Permanent Record</span>
      <span class="feed-count">{totalPosts} entries — Page {currentPage} of {lastPage}</span>
    </div>
    <div class="feed-header__rule"></div>
  </div>

  <div class="feed">
    {pagePosts.map((post, i) => (
      post.data.template === 'photos'
        ? <PostCardPhoto {post} entryIndex={(currentPage - 1) * 8 + i} />
        : <PostCard {post} entryIndex={(currentPage - 1) * 8 + i} />
    ))}
  </div>

  <Pagination
    {currentPage}
    {lastPage}
    prevUrl={currentPage > 1 ? (currentPage === 2 ? '/' : `/page/${currentPage - 1}`) : undefined}
    nextUrl={currentPage < lastPage ? `/page/${currentPage + 1}` : undefined}
    baseUrl="/page"
  />
</SiteLayout>

<style>
  .feed-header {
    padding-top: 3rem;
    margin-bottom: 0.5rem;
  }

  .feed-header__eyebrow {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .feed-issue {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .feed-count {
    font-family: var(--font-label);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-outline);
  }

  .feed-header__rule {
    height: 1px;
    background: var(--color-primary);
    opacity: 0.15;
  }
</style>
