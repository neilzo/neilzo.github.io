---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PostCard from '../../components/posts/PostCard.astro';
import PostCardPhoto from '../../components/posts/PostCardPhoto.astro';
import { getAllPosts } from '../../utils/getAllPosts';
import { ALL_TAGS, tagToSlug, slugToTag } from '../../utils/getPostsByTag';

export async function getStaticPaths() {
  const allPosts = await getAllPosts();

  return ALL_TAGS.map(tag => {
    const slug = tagToSlug(tag);
    const filtered = allPosts.filter(post => post.data.tags.includes(tag));
    return {
      params: { tag: slug },
      props: { posts: filtered, tagLabel: tag, tagSlug: slug },
    };
  });
}

const { posts, tagLabel, tagSlug } = Astro.props;
---

<SiteLayout title={`${tagLabel} — The Ordered Archive`} activeTag={tagSlug}>
  <div class="tag-page">
    <header class="tag-header">
      <span class="tag-header__label">Category</span>
      <div class="tag-header__title-row">
        <div class="tag-header__accent"></div>
        <h1 class="tag-header__title">{tagLabel}</h1>
      </div>
      <p class="tag-header__count">{posts.length} {posts.length === 1 ? 'entry' : 'entries'}</p>
      <div class="tag-header__rule"></div>
    </header>

    {posts.length === 0 ? (
      <p class="tag-empty">No entries yet under this category.</p>
    ) : (
      <div class="tag-feed">
        {posts.map((post, i) => (
          post.data.template === 'photos'
            ? <PostCardPhoto {post} entryIndex={i} />
            : <PostCard {post} entryIndex={i} />
        ))}
      </div>
    )}
  </div>
</SiteLayout>

<style>
  .tag-page {
    padding-top: 3rem;
    max-width: 52rem;
  }

  .tag-header {
    margin-bottom: 0.5rem;
  }

  .tag-header__label {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-outline);
    display: block;
    margin-bottom: 0.75rem;
  }

  .tag-header__title-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .tag-header__accent {
    width: 4px;
    background: var(--color-secondary);
    min-height: 2.5rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .tag-header__title {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-primary);
    margin: 0;
  }

  .tag-header__count {
    font-family: var(--font-label);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-outline);
    margin: 0 0 1rem;
    padding-left: calc(4px + 1rem);
  }

  .tag-header__rule {
    height: 1px;
    background: var(--color-primary);
    opacity: 0.1;
  }

  .tag-empty {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--color-outline);
    padding-top: 2rem;
  }
</style>
