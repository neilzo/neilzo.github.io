---
import { ALL_TAGS, tagToSlug } from '../../utils/getPostsByTag';

interface Props {
  activeTag?: string;
}
const { activeTag } = Astro.props;

const tagIcons: Record<string, string> = {
  Writing: 'edit_note',
  Photos: 'photo_camera',
  Reviews: 'star',
  Food: 'restaurant',
  Games: 'sports_esports',
  Movies: 'movie',
  TV: 'tv',
  Anime: 'animation',
  Drinks: 'local_bar',
  Books: 'menu_book',
  Travel: 'flight',
  Gear: 'construction',
  Software: 'code',
  'Tech Industry': 'business',
};
---

<aside class="sidenav" aria-label="Category navigation">
  <div class="sidenav-header">
    <span class="sidenav-label">Categories</span>
    <div class="sidenav-rule"></div>
  </div>

  <nav>
    {ALL_TAGS.map(tag => {
      const slug = tagToSlug(tag);
      const isActive = activeTag === slug;
      return (
        <a
          href={`/tags/${slug}`}
          class={`sidenav-link${isActive ? ' sidenav-link--active' : ''}`}
          aria-current={isActive ? 'page' : undefined}
        >
          <span class="material-symbols-outlined" aria-hidden="true">{tagIcons[tag] ?? 'label'}</span>
          <span>{tag}</span>
        </a>
      );
    })}
  </nav>
</aside>

<style>
  .sidenav {
    position: fixed;
    left: 0;
    top: 4rem;
    width: 14rem;
    height: calc(100vh - 4rem);
    overflow-y: auto;
    background: var(--color-surface-container-high);
    border-right: 1px solid rgba(23, 49, 36, 0.08);
    padding: 1.5rem 0;
    display: none;
    z-index: 40;
  }

  @media (min-width: 1024px) {
    .sidenav {
      display: block;
    }
  }

  .sidenav-header {
    padding: 0 1.25rem 1rem;
  }

  .sidenav-label {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-outline);
  }

  .sidenav-rule {
    height: 1px;
    background: var(--color-outline-variant);
    margin-top: 0.5rem;
  }

  .sidenav-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 1.25rem;
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .sidenav-link:hover {
    color: var(--color-secondary);
    background: rgba(148, 73, 37, 0.05);
  }

  .sidenav-link--active {
    color: var(--color-secondary);
    background: var(--color-surface);
    border-right: 2px solid var(--color-secondary);
  }

  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;
    font-size: 1rem;
    flex-shrink: 0;
  }
</style>
