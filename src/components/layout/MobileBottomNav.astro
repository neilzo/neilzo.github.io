---
interface Props {
  activeLink?: string;
}
const { activeLink = '' } = Astro.props;

const links = [
  { href: '/', icon: 'home', label: 'Home' },
  { href: '/tags', icon: 'tag', label: 'Tags' },
  { href: '/favorites', icon: 'favorite', label: 'Favorites' },
  { href: '/about', icon: 'person', label: 'About' },
];
---

<nav class="mobile-bottom-nav" aria-label="Mobile navigation">
  {links.map(({ href, icon, label }) => (
    <a
      href={href}
      class={`mobile-nav-link${activeLink === label ? ' mobile-nav-link--active' : ''}`}
      aria-label={label}
      aria-current={activeLink === label ? 'page' : undefined}
    >
      <span class="material-symbols-outlined" aria-hidden="true">{icon}</span>
    </a>
  ))}
</nav>

<style>
  .mobile-bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-around;
    background: rgba(251, 249, 244, 0.95);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(23, 49, 36, 0.08);
    z-index: 50;
  }

  @media (min-width: 768px) {
    .mobile-bottom-nav {
      display: none;
    }
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    color: rgba(23, 49, 36, 0.45);
    text-decoration: none;
    transition: color 0.15s;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link--active {
    color: var(--color-secondary);
  }

  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    font-size: 1.375rem;
  }
</style>
