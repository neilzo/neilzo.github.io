---
interface Props {
  activeLink?: string;
}
const { activeLink = '' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/favorites', label: 'Favorites' },
  { href: '/currently', label: 'Currently' },
  { href: '/setup', label: 'Setup' },
];
---

<header class="topnav">
  <a href="/" class="wordmark">Neil Daftary</a>

  <nav class="nav-links" aria-label="Main navigation">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class={`nav-link${activeLink === label ? ' nav-link--active' : ''}`}
      >
        {label}
      </a>
    ))}
  </nav>

  <a href="/tags" class="search-btn" aria-label="Browse tags">
    <span class="material-symbols-outlined" aria-hidden="true">tag</span>
  </a>
</header>

<style>
  .topnav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    background: rgba(251, 249, 244, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(23, 49, 36, 0.08);
    z-index: 50;
  }

  .wordmark {
    font-family: var(--font-headline);
    font-weight: 800;
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-links {
    display: none;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(23, 49, 36, 0.5);
    text-decoration: none;
    padding-bottom: 0.25rem;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-secondary);
  }

  .nav-link--active {
    color: var(--color-primary);
    border-bottom: 2px solid var(--color-secondary);
  }

  .search-btn {
    color: var(--color-primary);
    opacity: 0.6;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
  }

  @media (min-width: 768px) {
    .search-btn {
      visibility: hidden;
    }
  }

  .search-btn:hover {
    opacity: 1;
  }

  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    font-size: 1.25rem;
  }
</style>
