---
import type { CollectionEntry } from 'astro:content';
import PostMeta from './PostMeta.astro';
import StarRating from '../ui/StarRating.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  entryNum?: string;
}
const { post, entryNum } = Astro.props;
const { data } = post;

// Type guard — only render for review template
if (data.template !== 'review') throw new Error('PostCardReview requires template: review');

const { title, excerpt, rating, category } = data;

// Parse inline markdown: links, bold, italic
function renderInline(text: string): string {
  return text
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
---

<article class="review-card">
  <div class="review-card__meta">
    <PostMeta {post} {entryNum} />
  </div>
  <div class="review-card__body">
    <p class="review-card__label">Review / {category}</p>
    <h2 class="review-card__title">{title}</h2>
    <p class="review-card__text" set:html={renderInline(excerpt)} />
    <StarRating {rating} />
  </div>
</article>

<style>
  .review-card {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
  }

  @media (max-width: 640px) {
    .review-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .review-card__meta {
    padding-top: 0.25rem;
  }

  .review-card__body {
    background: var(--color-surface-container-high);
    border: 1px solid rgba(194, 200, 194, 0.15);
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .review-card__label {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .review-card__title {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 2rem;
    line-height: 1.25;
    color: var(--color-primary);
    margin: 0;
  }

  .review-card__text {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(23, 49, 36, 0.8);
    margin: 0;
  }

</style>
