---
import type { CollectionEntry } from 'astro:content';
import PostMeta from './PostMeta.astro';
import StarRating from '../ui/StarRating.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  entryNum?: string;
}
const { post, entryNum } = Astro.props;
const { data } = post;

// Type guard — only render for review template
if (data.template !== 'review') throw new Error('PostCardReview requires template: review');

const { title, excerpt, rating, category } = data;
const isLongReview = !!post.body?.trim();

// Parse inline markdown: links, bold, italic, footnote tooltips
function renderInline(text: string): string {
  let counter = 0;
  // Handle footnotes first (before other replacements that might consume parens)
  const withFootnotes = text.replace(/\\\^\(([^)]+)\)|\^\(([^)]+)\)/g, (match, escaped, content) => {
    if (escaped !== undefined) return `^(${escaped})`;
    counter++;
    const id = `fn-${counter}`;
    const safe = content.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    return `<span class="fn-marker" tabindex="0" aria-describedby="${id}" data-fn="${counter}">[${counter}]<span id="${id}" role="tooltip" class="fn-tooltip" aria-hidden="true">${safe}</span></span>`;
  });
  return withFootnotes
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
---

<article class={`review-card${isLongReview ? ' review-card--long' : ''}`}>
  <div class="review-card__meta">
    <PostMeta {post} {entryNum} />
  </div>
  <div class="review-card__body">
    <p class="review-card__label">{!isLongReview && 'Mini'} Review / {category}</p>
    <h2 class="review-card__title">
      {isLongReview
        ? <a href={`/posts/${post.slug}`}>{title}</a>
        : title}
    </h2>
    <p class="review-card__text" set:html={renderInline(excerpt)} />
    <StarRating {rating} />
    {isLongReview && (
      <div class="review-card__actions">
        <a href={`/posts/${post.slug}`} class="review-card__cta">Read</a>
      </div>
    )}
  </div>
</article>

<style>
  .review-card {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
  }

  @media (max-width: 640px) {
    .review-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .review-card__meta {
    padding-top: 0.25rem;
  }

  .review-card__body {
    background: var(--color-surface-container-high);
    border: 1px solid rgba(194, 200, 194, 0.15);
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .review-card--long .review-card__body {
    background: none;
    border: none;
    padding: 0;
    gap: 0.875rem;
  }

  .review-card__label {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .review-card__title {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 2rem;
    line-height: 1.25;
    color: var(--color-primary);
    margin: 0;
  }

  .review-card--long .review-card__title {
    font-family: var(--font-headline);
    font-weight: 700;
    line-height: 1.3;
  }

  .review-card--long .review-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .review-card--long .review-card__title a:hover {
    color: var(--color-secondary);
  }

  .review-card__text {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(23, 49, 36, 0.8);
    margin: 0;
  }

  .review-card--long .review-card__text {
    line-height: 1.7;
    color: var(--color-on-surface-variant);
  }

  .review-card__actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .review-card__cta {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-secondary);
    padding-bottom: 0.125rem;
    transition: color 0.15s;
  }

  .review-card__cta:hover {
    color: var(--color-secondary);
  }

</style>
