---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  plateLabel?: string;
}
const { src, alt, caption, plateLabel } = Astro.props;
---

<figure class="image-frame">
  <div class="image-frame__mat">
    <img src={src} alt={alt} class="image-frame__img" loading="lazy" />
    {plateLabel && (
      <div class="image-frame__plate">
        <span>{plateLabel}</span>
        {caption && <span class="image-frame__caption-inline"> — {caption}</span>}
      </div>
    )}
  </div>
  {caption && !plateLabel && (
    <figcaption class="image-frame__caption">{caption}</figcaption>
  )}
</figure>

<style>
  .image-frame {
    margin: 0;
  }

  .image-frame__mat {
    background: var(--color-surface-container-low);
    border: 1px solid rgba(194, 200, 194, 0.3);
    padding: 0.75rem;
    position: relative;
    overflow: hidden;
  }

  .image-frame__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .image-frame__mat:hover .image-frame__img {
    transform: scale(1.02);
  }

  .image-frame__plate {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    background: var(--color-primary);
    color: white;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
  }

  .image-frame__caption-inline {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  .image-frame__caption {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.8rem;
    color: var(--color-outline);
    margin-top: 0.5rem;
    padding-left: 0.25rem;
  }
</style>
