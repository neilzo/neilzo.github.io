---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  plateLabel?: string;
  lightboxIndex?: number;
}
const { src, alt, caption, plateLabel, lightboxIndex } = Astro.props;
const isLocal = typeof src !== 'string';
const hasLightbox = lightboxIndex !== undefined;
---

<figure class="image-frame">
  <div class="image-frame__mat">
    {hasLightbox ? (
      <button
        class="image-frame__lightbox-trigger"
        data-lightbox-index={lightboxIndex}
        data-lightbox-src={isLocal ? (src as ImageMetadata).src : src as string}
        data-lightbox-alt={alt}
        data-lightbox-caption={caption ?? ''}
        aria-label={`View larger: ${alt}`}
        type="button"
      >
        {isLocal
          ? <Image src={src as ImageMetadata} {alt} class="image-frame__img" />
          : <img src={src as string} {alt} class="image-frame__img" loading="lazy" />
        }
      </button>
    ) : (
      isLocal
        ? <Image src={src as ImageMetadata} {alt} class="image-frame__img" />
        : <img src={src as string} {alt} class="image-frame__img" loading="lazy" />
    )}
    {plateLabel && (
      <div class="image-frame__plate">
        <span>{plateLabel}</span>
        {caption && <span class="image-frame__caption-inline"> — {caption}</span>}
      </div>
    )}
    {hasLightbox && (
      <div class="image-frame__expand-badge" aria-hidden="true">
        <span class="material-symbols-outlined">open_in_full</span>
        Expand
      </div>
    )}
  </div>
  {caption && !plateLabel && (
    <figcaption class="image-frame__caption">{caption}</figcaption>
  )}
</figure>

<style>
  .image-frame {
    margin: 0 0 2rem 0;
  }

  .image-frame__mat {
    background: var(--color-surface-container-low);
    border: 1px solid rgba(194, 200, 194, 0.3);
    padding: 0.75rem;
    position: relative;
    overflow: hidden;
  }

  .image-frame__lightbox-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
  }

  .image-frame__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .image-frame__mat:hover .image-frame__img {
    transform: scale(1.02);
  }

  .image-frame__plate {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    background: var(--color-primary);
    color: white;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
  }

  .image-frame__expand-badge {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: var(--color-primary);
    color: white;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    pointer-events: none;
  }

  .image-frame__expand-badge .material-symbols-outlined {
    font-size: 0.75rem;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;
  }

  .image-frame__caption-inline {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  .image-frame__caption {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-outline);
    margin-top: 0.75rem;
  }
</style>
