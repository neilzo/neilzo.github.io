---
import type { CollectionEntry } from 'astro:content';
import PostMeta from './PostMeta.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  entryNum?: string;
}
const { post, entryNum } = Astro.props;
const { data } = post;

if (data.template !== 'link') throw new Error('PostCardLink requires template: link');

const { title, url, source, quote, excerpt } = data;

const displayHost = (() => {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
})();
---

<article class="link-card">
  <div class="link-card__meta">
    <PostMeta {post} {entryNum} />
  </div>
  <div class="link-card__body">
    <!--<p class="link-card__label">Link / Reading</p>-->
    <h2 class="link-card__title">
      <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
    </h2>
    {(source || displayHost) && (
      <p class="link-card__source">{source ?? displayHost}</p>
    )}
    {quote && (
      <blockquote class="link-card__quote">
        <p>{quote}</p>
      </blockquote>
    )}
    <p class="link-card__excerpt">{excerpt}</p>
  </div>
</article>

<style>
  .link-card {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
  }

  @media (max-width: 640px) {
    .link-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .link-card__meta {
    padding-top: 0.25rem;
  }

  .link-card__body {
    padding: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .link-card__label {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin: 0;
  }

  .link-card__title {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 2rem;
    line-height: 1.25;
    color: var(--color-primary);
    margin: 0;
  }

  .link-card__title a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--color-secondary);
    transition: color 0.15s, border-color 0.15s;
  }

  .link-card__title a:hover {
    color: var(--color-secondary);
    border-color: transparent;
  }

  .link-card__source {
    font-family: var(--font-label);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-outline);
    margin: 0;
    margin-top: -0.5rem;
  }

  .link-card__quote {
    margin: 0;
    padding: 0.875rem 1.25rem;
    border-left: 2px solid var(--color-secondary);
    background: rgba(23, 49, 36, 0.04);
  }

  .link-card__quote p {
    font-family: var(--font-body);
    line-height: 1.7;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  .link-card__excerpt {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(23, 49, 36, 0.8);
    margin: 1rem 0 0 0;
  }
</style>
