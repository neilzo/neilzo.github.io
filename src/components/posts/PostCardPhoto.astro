---
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import PostMeta from './PostMeta.astro';
import PostImageFrame from './PostImageFrame.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  entryNum?: string;
}
const { post, entryNum } = Astro.props;
const { data, slug } = post;

const firstImage = data.template === 'photos' ? data.images[0] : undefined;

const localImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/posts/**/*.{jpg,jpeg,png,webp,gif,avif}',
  { eager: true }
);

function resolveImageSrc(postSlug: string, src: string): ImageMetadata | string {
  if (src.startsWith('http') || src.startsWith('//')) return src;
  const filename = src.startsWith('./') ? src.slice(2) : src;
  const key = `/src/content/posts/${postSlug}/${filename}`;
  return localImages[key]?.default ?? src;
}
---

<article class="post-card-photo">
  <div class="post-card-photo__meta">
    <PostMeta {post} {entryNum} />
  </div>
  <div class="post-card-photo__body">
    <h2 class="post-card-photo__title">
      <a href={`/posts/${slug}`}>{data.title}</a>
    </h2>
    {firstImage && (
      <a href={`/posts/${slug}`} class="post-card-photo__image-link" tabindex="-1" aria-hidden="true">
        <PostImageFrame
          src={resolveImageSrc(slug, firstImage.src)}
          alt={firstImage.alt}
          plateLabel={firstImage.plateLabel}
        />
      </a>
    )}
    {data.excerpt && (
      <p class="post-card-photo__excerpt">{data.excerpt}</p>
    )}
    <a href={`/posts/${slug}`} class="post-card-photo__cta">View Gallery</a>
  </div>
</article>

<style>
  .post-card-photo {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    //border-bottom: 1px solid rgba(194, 200, 194, 0.3);
  }

  @media (max-width: 640px) {
    .post-card-photo {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .post-card-photo__meta {
    padding-top: 0.25rem;
  }

  .post-card-photo__body {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .post-card-photo__image-link {
    display: block;
  }

  .post-card-photo__title {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.3;
    color: var(--color-primary);
    //margin: 0 0 1rem 0;
  }

  .post-card-photo__title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-card-photo__title a:hover {
    color: var(--color-secondary);
  }

  .post-card-photo__excerpt {
    font-family: var(--font-body);
    line-height: 1.7;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  .post-card-photo__cta {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-secondary);
    padding-bottom: 0.125rem;
    width: fit-content;
    transition: color 0.15s;
  }

  .post-card-photo__cta:hover {
    color: var(--color-secondary);
  }
</style>
