---
import type { CollectionEntry } from 'astro:content';
import PostMeta from './PostMeta.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  entryNum?: string;
}
const { post, entryNum } = Astro.props;
const { data, slug } = post;
---

<article class="post-card">
  <div class="post-card__meta">
    <PostMeta {post} {entryNum} />
  </div>
  <div class="post-card__body">
    <h2 class="post-card__title">
      <a href={`/posts/${slug}`}>{data.title}</a>
    </h2>
    {data.excerpt && (
      <p class="post-card__excerpt">{data.excerpt}</p>
    )}
    {'youtubeId' in data && data.youtubeId && (
      <a
        href={`https://www.youtube.com/watch?v=${data.youtubeId}`}
        class="post-card__youtube-thumb"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Watch on YouTube"
      >
        <img
          src={`https://img.youtube.com/vi/${data.youtubeId}/hqdefault.jpg`}
          alt={`YouTube thumbnail for ${data.title}`}
          loading="lazy"
          width="480"
          height="360"
        />
        <span class="post-card__youtube-play" aria-hidden="true">▶</span>
      </a>
    )}
    <div class="post-card__actions">
      <a href={`/posts/${slug}`} class="post-card__cta">Read</a>
    </div>
  </div>
</article>

<style>
  .post-card {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    //border-bottom: 1px solid rgba(194, 200, 194, 0.3);
  }

  @media (max-width: 640px) {
    .post-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .post-card__meta {
    padding-top: 0.25rem;
  }

  .post-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .post-card__title {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.3;
    color: var(--color-primary);
    margin: 0;
  }

  .post-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-card__title a:hover {
    color: var(--color-secondary);
  }

  .post-card__excerpt {
    font-family: var(--font-body);
    //font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  .post-card__actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .post-card__cta {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-secondary);
    padding-bottom: 0.125rem;
    transition: color 0.15s;
  }

  .post-card__cta:hover {
    color: var(--color-secondary);
  }

  .post-card__youtube-thumb {
    position: relative;
    display: block;
    width: 100%;
    max-width: 28rem;
  }

  .post-card__youtube-thumb img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .post-card__youtube-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: white;
    background: rgba(0, 0, 0, 0.35);
    transition: background 0.15s;
  }

  .post-card__youtube-thumb:hover .post-card__youtube-play {
    background: rgba(0, 0, 0, 0.55);
  }
</style>
