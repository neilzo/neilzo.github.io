---
import type { CollectionEntry } from 'astro:content';
import PostMeta from './PostMeta.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  entryIndex?: number;
}
const { post, entryIndex } = Astro.props;
const { data, slug } = post;
---

<article class="post-card">
  <div class="post-card__meta">
    <PostMeta {post} {entryIndex} />
  </div>
  <div class="post-card__body">
    <h2 class="post-card__title">
      <a href={`/posts/${slug}`}>{data.title}</a>
    </h2>
    {data.excerpt && (
      <p class="post-card__excerpt">{data.excerpt}</p>
    )}
    <div class="post-card__actions">
      <a href={`/posts/${slug}`} class="post-card__cta">Read</a>
    </div>
  </div>
</article>

<style>
  .post-card {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    //border-bottom: 1px solid rgba(194, 200, 194, 0.3);
  }

  @media (max-width: 640px) {
    .post-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .post-card__meta {
    padding-top: 0.25rem;
  }

  .post-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .post-card__title {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-primary);
    margin: 0;
  }

  .post-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-card__title a:hover {
    color: var(--color-secondary);
  }

  .post-card__excerpt {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  .post-card__actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .post-card__cta {
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-secondary);
    padding-bottom: 0.125rem;
    transition: color 0.15s;
  }

  .post-card__cta:hover {
    color: var(--color-secondary);
  }
</style>
