---
interface Props {
  name: string;
  acquired?: string;
}
const { name, acquired } = Astro.props;
---

<li class="setup-item">
  <div class="setup-item__header">
    <span class="setup-item__name">{name}</span>
    {acquired && <span class="setup-item__acquired">{acquired}</span>}
  </div>
  <div class="setup-item__desc">
    <slot />
  </div>
</li>

<style>
  .setup-item {
    list-style: none;
    padding: 1.125rem 0;
    border-bottom: 1px solid rgba(194, 200, 194, 0.25);
  }

  .setup-item__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .setup-item__name {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--color-primary);
  }

  .setup-item__acquired {
    font-family: var(--font-label);
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-outline);
    white-space: nowrap;
  }

  .setup-item__desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-on-surface-variant);
    margin: 0.375rem 0 0;
  }

  .setup-item__desc :global(p) {
    margin: 0;
  }

  .setup-item__desc :global(a) {
    color: var(--color-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgb(166 93 70 / 0.45);
  }

  .setup-item__desc :global(a:hover) {
    text-decoration-color: rgb(166 93 70 / 1);
  }
</style>
