---
import BaseLayout from './BaseLayout.astro';
import TopNav from '../components/layout/TopNav.astro';
import SideNav from '../components/layout/SideNav.astro';
import MobileBottomNav from '../components/layout/MobileBottomNav.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  activeNav?: string;
  activeTag?: string;
}

const { title, description, ogImage, activeNav, activeTag } = Astro.props;
---

<BaseLayout {title} {description} {ogImage}>
  <TopNav activeLink={activeNav} />
  <SideNav activeTag={activeTag} />

  <div class="site-wrap">
    <main class="main-content">
      <slot />
    </main>
    <Footer />
  </div>

  <MobileBottomNav activeLink={activeNav} />
</BaseLayout>

<style>
  .site-wrap {
    padding-top: 4rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-image: linear-gradient(to right, rgba(23, 49, 36, 0.04) 1px, transparent 1px), linear-gradient(to bottom, rgba(23, 49, 36, 0.04) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .main-content {
    padding: 0 1.5rem;
    max-width: 64rem;
    margin: 0 auto;
    width: 100%;
    flex: 1;
  }

  @media (min-width: 1024px) {
    .site-wrap {
      padding-left: 14rem;
    }
    .main-content {
      padding: 0 2.5rem;
    }
  }
</style>
